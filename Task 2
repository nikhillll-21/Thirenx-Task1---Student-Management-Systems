#include <iostream>
#include <fstream>
#include <cstdio>
#include <cstring>

using namespace std;

class Bank
{
private:
    int accountNo;
    char name[50];
    float balance;

public:

    void createAccount()
    {
        cout << "\nEnter Account Number: ";
        cin >> accountNo;

        cin.ignore();

        cout << "Enter Customer Name: ";
        cin.getline(name, 50);

        cout << "Enter Initial Balance: ";
        cin >> balance;
    }

    void showAccount()
    {
        cout << "\nAccount Number : " << accountNo;
        cout << "\nCustomer Name  : " << name;
        cout << "\nBalance        : " << balance << endl;
    }

    int getAccountNo()
    {
        return accountNo;
    }

    void deposit()
    {
        float amt;

        cout << "\nEnter Amount to Deposit: ";
        cin >> amt;

        balance += amt;

        cout << "\nAmount Deposited Successfully!";
    }

    void withdraw()
    {
        float amt;

        cout << "\nEnter Amount to Withdraw: ";
        cin >> amt;

        if(amt <= balance)
        {
            balance -= amt;
            cout << "\nWithdrawal Successful!";
        }
        else
        {
            cout << "\nInsufficient Balance!";
        }
    }

    void balanceInquiry()
    {
        cout << "\nCurrent Balance: " << balance << endl;
    }
};

void createNewAccount()
{
    Bank b;

    ofstream file("bank.dat", ios::binary | ios::app);

    b.createAccount();

    file.write((char*)&b, sizeof(b));

    file.close();

    cout << "\nAccount Created Successfully!\n";
}

void displayAccounts()
{
    Bank b;

    ifstream file("bank.dat", ios::binary);

    cout << "\n===== Account Records =====\n";

    while(file.read((char*)&b, sizeof(b)))
    {
        b.showAccount();
        cout << "----------------------------\n";
    }

    file.close();
}

void depositAmount()
{
    Bank b;

    int accNo;
    bool found = false;

    fstream file("bank.dat", ios::binary | ios::in | ios::out);

    cout << "\nEnter Account Number: ";
    cin >> accNo;

    while(file.read((char*)&b, sizeof(b)))
    {
        if(b.getAccountNo() == accNo)
        {
            b.deposit();

            int pos = (-1) * sizeof(b);

            file.seekp(pos, ios::cur);

            file.write((char*)&b, sizeof(b));

            found = true;

            break;
        }
    }

    file.close();

    if(!found)
    {
        cout << "\nAccount Not Found!";
    }
}

void withdrawAmount()
{
    Bank b;

    int accNo;
    bool found = false;

    fstream file("bank.dat", ios::binary | ios::in | ios::out);

    cout << "\nEnter Account Number: ";
    cin >> accNo;

    while(file.read((char*)&b, sizeof(b)))
    {
        if(b.getAccountNo() == accNo)
        {
            b.withdraw();

            int pos = (-1) * sizeof(b);

            file.seekp(pos, ios::cur);

            file.write((char*)&b, sizeof(b));

            found = true;

            break;
        }
    }

    file.close();

    if(!found)
    {
        cout << "\nAccount Not Found!";
    }
}

void checkBalance()
{
    Bank b;

    int accNo;
    bool found = false;

    ifstream file("bank.dat", ios::binary);

    cout << "\nEnter Account Number: ";
    cin >> accNo;

    while(file.read((char*)&b, sizeof(b)))
    {
        if(b.getAccountNo() == accNo)
        {
            b.balanceInquiry();

            found = true;

            break;
        }
    }

    file.close();

    if(!found)
    {
        cout << "\nAccount Not Found!";
    }
}

int main()
{
    int choice;

    do
    {
        cout << "\n===== Bank Management System =====\n";

        cout << "1. Create New Account\n";
        cout << "2. Deposit Amount\n";
        cout << "3. Withdraw Amount\n";
        cout << "4. Balance Inquiry\n";
        cout << "5. Display All Accounts\n";
        cout << "6. Exit\n";

        cout << "\nEnter Your Choice: ";
        cin >> choice;

        switch(choice)
        {
            case 1:
                createNewAccount();
                break;

            case 2:
                depositAmount();
                break;

            case 3:
                withdrawAmount();
                break;

            case 4:
                checkBalance();
                break;

            case 5:
                displayAccounts();
                break;

            case 6:
                cout << "\nThank You for Using Bank Management System!\n";
                break;

            default:
                cout << "\nInvalid Choice!";
        }

    } while(choice != 6);

    return 0;
}
